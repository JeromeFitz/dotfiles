{
  "name": "@jeromefitz/dotfiles",
  "version": "0.0.1",
  "description": "Jerome Fitzgerald’s dotfiles",
  "repository": {
    "type": "git",
    "url": "https://github.com/JeromeFitz/dotfiles"
  },
  "bugs": {
    "url": "https://github.com/JeromeFitz/dotfiles/issues"
  },
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10 <11"
  },
  "keywords": [
    "dotfiles"
  ],
  "scripts": {
    "biome:check": "biome check",
    "biome:write": "biome check --write",
    "bootstrap": "sh ./scripts/bootstrap",
    "build": "pnpm run bootstrap",
    "clean": "sh ./scripts/clean",
    "clean:install": "pnpm run clean && pnpm run uninstall && pnpm install && pnpm run bootstrap",
    "deduplicate": "npx pnpm-deduplicate",
    "deduplicate:check": "npx pnpm-deduplicate --list",
    "format": "pnpm format:biome:write && pnpm format:prettier:write",
    "format:biome:base": "biome format",
    "format:biome:check": "pnpm format:biome:base",
    "format:biome:write": "pnpm format:biome:base --write",
    "format:prettier:base": "prettier \"./**/package.json\" --ignore-unknown --ignore-path",
    "format:prettier:check": "pnpm format:prettier:base --check",
    "format:prettier:write": "pnpm format:prettier:base --write",
    "lint": "pnpm run lint:biome && pnpm run format:prettier:check",
    "lint:biome": "biome lint",
    "preinstall": "npx only-allow pnpm",
    "prepare": "pnpm is-ci || pnpm dlx husky@9.1.7",
    "semantic-release": "semantic-release",
    "uninstall": "sh ./scripts/uninstall"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.11",
    "@jeromefitz/conventional-gitmoji": "5.0.0",
    "@jeromefitz/prettier-config": "3.0.1",
    "@jeromefitz/release-notes-generator": "4.0.0",
    "@jeromefitz/semantic": "12.0.2",
    "ccommit": "4.0.1",
    "dotenv": "17.4.2",
    "is-ci": "4.1.0"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": "7.0.6",
      "postcss": "8.5.9",
      "semver": "7.7.4",
      "word-wrap": "1.2.5"
    },
    "patchedDependencies": {
      "@semantic-release/commit-analyzer@13.0.1": "patches/@semantic-release__commit-analyzer@13.0.0.patch"
    }
  }
}
